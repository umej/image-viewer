<Window x:Class="ImageViewer.Dialogs.RawImageLoadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RAW画像を読み込む" >
        <!--Height="350" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"-->
    <Grid Background="#F5F5F5">
        <StackPanel Margin="20" VerticalAlignment="Stretch">
            
            <!-- ファイルパス入力エリア -->
            <TextBlock Text="ファイルパス:" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/> 
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathTextBox" 
                         Grid.Column="0" 
                         Padding="8" 
                         VerticalAlignment="Center"
                         IsReadOnly="True"/>
                <Button x:Name="BrowseButton" 
                        Grid.Column="1" 
                        Content="参照..." 
                        Click="BrowseButton_Click" 
                        Padding="15,8" 
                        Margin="10,0,0,0"
                        Background="#007ACC" 
                        Foreground="White"/>
            </Grid>

            <!-- 幅と高さ入力エリア -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="幅 (Width):" FontWeight="Bold" Grid.Row="0" Grid.Column="0" Margin="0,0,10,5"/>
                <TextBox x:Name="WidthTextBox" 
                         Grid.Row="1" 
                         Grid.Column="0" 
                         Padding="8" 
                         Margin="0,0,10,0"/>

                <TextBlock Text="高さ (Height):" FontWeight="Bold" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>
                <TextBox x:Name="HeightTextBox" 
                         Grid.Row="1" 
                         Grid.Column="1" 
                         Padding="8"/>
            </Grid>

            <!-- ビット深度選択エリア -->
            <TextBlock Text="ビット深度 (Bit Depth):" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="BitDepthComboBox" 
                      Padding="8" 
                      Margin="0,0,0,15"/>
            <!--IsReadOnly="True"-->

            <!-- Bayer配列パターン選択エリア -->
            <TextBlock Text="Bayer配列パターン:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="BayerPatternComboBox" 
                      Padding="8" 
                      Margin="0,0,0,20"/>
            <!--IsReadOnly="True"-->

                <!-- ボタンエリア -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="OkButton" 
                        Content="読み込む" 
                        Click="OkButton_Click" 
                        Grid.Column="1" 
                        Padding="20,8" 
                        Margin="0,0,10,0"
                        Background="#007ACC" 
                        Foreground="White"/>

                <Button x:Name="CancelButton" 
                        Content="キャンセル" 
                        Click="CancelButton_Click" 
                        Grid.Column="2" 
                        Padding="20,8"
                        Background="#E81828" 
                        Foreground="White"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>